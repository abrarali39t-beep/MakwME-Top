rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email in [
          'abrarrtallks@gmail.com',
          'contact.abrarrtallks@gmail.com'
        ];
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ─── BUSINESSES ─────────────────────────────────────────────────────
    match /businesses/{bizId} {
      // Anyone can read approved listings
      allow read: if resource.data.status == 'approved';

      // Authenticated & verified can read their own (any status)
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;

      // Admin can read all
      allow read: if isAdmin();

      // Verified users can create
      allow create: if isEmailVerified()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.user_email == request.auth.token.email
        && request.resource.data.status == 'pending'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200;

      // Owner can update their own (except status and user_id)
      allow update: if isOwner(resource.data.user_id)
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.user_email == resource.data.user_email
        && request.resource.data.status == 'pending'; // must reset to pending on edit

      // Admin can update (for approval/rejection)
      allow update: if isAdmin();

      // Owner can delete their own
      allow delete: if isOwner(resource.data.user_id);

      // Admin can delete any
      allow delete: if isAdmin();
    }

    // ─── REVIEWS ────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;

      // Verified users can create reviews (one per business enforced in code)
      allow create: if isEmailVerified()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() <= 1000;

      // Only review owner can edit (rating & comment only)
      allow update: if isOwner(resource.data.user_id)
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.business_id == resource.data.business_id
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Review owner or admin can delete
      allow delete: if isOwner(resource.data.user_id) || isAdmin();
    }

    // ─── CONTACT MESSAGES ───────────────────────────────────────────────
    match /contact_messages/{msgId} {
      // Anyone (logged in) can create
      allow create: if isSignedIn()
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;

      // Only admin can read
      allow read: if isAdmin();

      // No updates/deletes by regular users
      allow update, delete: if isAdmin();
    }

    // ─── LIVE CHAT CONVERSATIONS ─────────────────────────────────────────
    match /chat_conversations/{convId} {
      // User can read & write their own conversation
      allow read, write: if isSignedIn() && resource.data.user_id == request.auth.uid;

      // User can create a new conversation for themselves
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;

      // Admin can read & write all conversations
      allow read, write: if isAdmin();

      // ── Chat Messages (subcollection) ──
      match /messages/{msgId} {
        // User can read messages in their own conversation
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/chat_conversations/$(convId)).data.user_id == request.auth.uid;

        // User can create messages in their own conversation
        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/chat_conversations/$(convId)).data.user_id == request.auth.uid
          && request.resource.data.sender == 'user'
          && request.resource.data.sender_id == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        // Admin can read & write all messages
        allow read, write: if isAdmin();

        // No one can delete messages
        allow delete: if false;
      }
    }
  }
}
